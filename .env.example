# OpenAI
OPENAI_API_KEY=sk-...

# Discord bot token + application id
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=

# State directory — persona, access, pinned facts, embeddings, summaries
# Default: ~/.gpt/channels/discord/
GPT_STATE_DIR=

# Default model (gpt-5.6 | gpt-5.6-terra | gpt-5.6-luna)
GPT_MODEL=gpt-5.6

# Optional: log file path (default: <state-dir>/gpt.log)
GPT_LOG_FILE=

# Optional: connect to an MCP server at boot and auto-register its tools.
# Streamable-HTTP transport. Tools are bridged into OpenAI function-calls.
# GPT_MCP_URL=http://localhost:8765/mcp
# GPT_MCP_LABEL=ibkr

# Optional: model used for background summarization (default gpt-5.6-luna).
GPT_SUMMARIZATION_MODEL=
GPT_SUMMARIZATION_THRESHOLD=50
GPT_SUMMARIZATION_BATCH_LIMIT=500

# Optional: model used by web_search side-call (default gpt-4o-mini-search-preview).
GPT_SEARCH_MODEL=

# Optional: embedding model (default text-embedding-3-small).
GPT_EMBEDDING_MODEL=
